{
  "dryRun": true,
  "experimental": false,
  "hooksPath": "<PROJECT>/.codex/hooks.json",
  "managedBlock": {
    "Stop": [
      {
        "hooks": [
          {
            "command": "token-optimizer summarize --hook stop --hook-mode inactive-placeholder-v1",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "_tokenOptimizer": {
      "behavior": "inactive-placeholder-v1",
      "description": "Managed by Token Optimizer. Experimental Stop-hook entry invoking a no-op command; remove with uninstall.",
      "feature": "experimental-stop-hook",
      "marker": "TOKEN_OPTIMIZER_MANAGED",
      "profile": "quiet",
      "requiresFreshConsentForActiveBehavior": true
    }
  },
  "managedMarker": "TOKEN_OPTIMIZER_MANAGED",
  "profile": "quiet",
  "project": "<PROJECT>",
  "warnings": [
    "Stop-hook entry installation is experimental and invokes a no-op command in 0.1.0; use --experimental with --yes only after reviewing the dry-run plan."
  ]
}
